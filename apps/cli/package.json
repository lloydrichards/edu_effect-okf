{
  "name": "@lloydrichards/edu_effect-okf",
  "version": "0.1.0",
  "description": "CLI for validating, exploring, embedding, and querying Open Knowledge Format bundles.",
  "type": "module",
  "bin": {
    "okf": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lloydrichards/edu_effect-okf.git",
    "directory": "apps/cli"
  },
  "homepage": "https://github.com/lloydrichards/edu_effect-okf#readme",
  "bugs": {
    "url": "https://github.com/lloydrichards/edu_effect-okf/issues"
  },
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir=dist --target=bun --minify --banner='#!/usr/bin/env bun' && chmod +x dist/index.js",
    "build:types": "tsc --emitDeclarationOnly",
    "dev": "bun run src/index.ts",
    "test": "vitest run --passWithNoTests",
    "type-check": "tsc --noEmit",
    "clean": "git clean -xdf .cache .turbo dist node_modules"
  },
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.84",
    "@repo/ai": "workspace:*",
    "@repo/rag": "workspace:*",
    "@repo/okf": "workspace:*",
    "@repo/domain": "workspace:*",
    "effect": "4.0.0-beta.84",
    "effect-boxes": "^0.17.0"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.84",
    "@repo/config-typescript": "workspace:*",
    "@types/bun": "^1.2.17",
    "typescript": "6.0.3",
    "vitest": "^4.1.4"
  }
}
